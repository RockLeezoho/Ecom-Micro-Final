# Cart Service Environment Configuration
# Production Mode: Connects through ProxySQL connection pooler
DJANGO_SECRET_KEY=your-secret-key
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

CART_SERVICE_PORT=8004

MYSQL_DATABASE=cart_db
MYSQL_USER=cart_user
MYSQL_PASSWORD=123456
MYSQL_ROOT_PASSWORD=root
CART_DB_PORT=3310

# MySQL Connection (via ProxySQL pooler for production)
# For direct DB access (dev/debug), set DB_HOST=cart-db and DB_PORT=3306
DB_HOST=proxysql
DB_PORT=6033
DB_NAME=cart_db
DB_USER=cart_user
DB_PASSWORD=123456

REDIS_HOST=redis
REDIS_PORT=6379
INTERNAL_SERVICE_TOKEN=change-me-in-dev
