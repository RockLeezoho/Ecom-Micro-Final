# PgBouncer Environment File
# This file is primarily informational; pgbouncer uses pgbouncer.ini

# Database Backend
PGBOUNCER_DB_HOST=product-db
PGBOUNCER_DB_PORT=5432
PGBOUNCER_DB_NAME=product_service
PGBOUNCER_DB_USER=product_user
PGBOUNCER_DB_PASSWORD=product_pass

# PgBouncer Admin
PGBOUNCER_ADMIN_USER=admin
PGBOUNCER_ADMIN_PASSWORD=admin

# Connection Pool Settings
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=25
PGBOUNCER_MIN_POOL_SIZE=10
PGBOUNCER_MAX_DB_CONNECTIONS=100
PGBOUNCER_MAX_USER_CONNECTIONS=100

# Port
PGBOUNCER_PORT=6432
