# ProxySQL Environment File
# This file is primarily informational; proxysql uses proxysql.cnf

# ProxySQL Admin Interface
PROXYSQL_ADMIN_USER=admin
PROXYSQL_ADMIN_PASSWORD=admin
PROXYSQL_ADMIN_PORT=6032

# ProxySQL Client Port (used by services)
PROXYSQL_MYSQL_PORT=6033

# Backend MySQL Servers
PROXYSQL_USER_DB_HOST=user-db
PROXYSQL_USER_DB_PORT=3306
PROXYSQL_USER_DB_NAME=user_db
PROXYSQL_USER_DB_USER=user_user
PROXYSQL_USER_DB_PASSWORD=user_pass

PROXYSQL_CART_DB_HOST=cart-db
PROXYSQL_CART_DB_PORT=3306
PROXYSQL_CART_DB_NAME=cart_db
PROXYSQL_CART_DB_USER=cart_user
PROXYSQL_CART_DB_PASSWORD=cart_pass

PROXYSQL_ORDER_DB_HOST=order-db
PROXYSQL_ORDER_DB_PORT=3306
PROXYSQL_ORDER_DB_NAME=order_db
PROXYSQL_ORDER_DB_USER=order_user
PROXYSQL_ORDER_DB_PASSWORD=order_pass

PROXYSQL_PAYMENT_DB_HOST=payment-db
PROXYSQL_PAYMENT_DB_PORT=3306
PROXYSQL_PAYMENT_DB_NAME=payment_db
PROXYSQL_PAYMENT_DB_USER=payment_user
PROXYSQL_PAYMENT_DB_PASSWORD=payment_pass

PROXYSQL_SHIPPING_DB_HOST=shipping-db
PROXYSQL_SHIPPING_DB_PORT=3306
PROXYSQL_SHIPPING_DB_NAME=shipping_db
PROXYSQL_SHIPPING_DB_USER=shipping_user
PROXYSQL_SHIPPING_DB_PASSWORD=shipping_pass

# Connection Pooling
PROXYSQL_MAX_CONNECTIONS=2048
PROXYSQL_DEFAULT_QUERY_TIMEOUT=36000
PROXYSQL_POLL_TIMEOUT=2000

# Per-Backend Settings
PROXYSQL_MAX_DB_CONNECTIONS=200
PROXYSQL_MAX_USER_CONNECTIONS=100
