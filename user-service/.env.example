# User Service Environment Configuration
# Production Mode: Connects through ProxySQL connection pooler
# For direct DB access (dev/debug), change DB_HOST and DB_PORT

DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=0

USER_SERVICE_PORT=8001

# MySQL Connection (via ProxySQL pooler for production)
MYSQL_ENGINE=django.db.backends.mysql
DB_HOST=proxysql
DB_PORT=6033
DB_NAME=user_db
DB_USER=user_user
DB_PASSWORD=user_pass

# Legacy MySQL env vars (for backward compatibility / direct DB access)
# To use direct DB connection, change these values:
# DB_HOST=user-db
# DB_PORT=3306
MYSQL_DATABASE=user_db
MYSQL_USER=user_user
MYSQL_PASSWORD=user_pass
MYSQL_ROOT_PASSWORD=root_password
USER_DB_PORT=3306

JWT_SECRET_KEY=change-me-in-local-test
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# Cloudinary config for image upload
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=